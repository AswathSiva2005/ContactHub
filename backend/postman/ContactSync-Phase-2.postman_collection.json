{
  "info": {
    "name": "ContactSync - Phase 2",
    "description": "Batch and contact API tests. Run requests in order; the final request removes the test batch and its remaining contacts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api/v1" },
    { "key": "batchId", "value": "postman-batch-2026" },
    { "key": "contactUuid", "value": "postman-contact-001" }
  ],
  "item": [
    {
      "name": "1 - Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('API and database are ready', () => {", "  pm.response.to.have.status(200);", "  pm.expect(pm.response.json().data.database).to.eql('connected');", "});"] } }]
    },
    {
      "name": "2 - Create Batch",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"batchId\": \"{{batchId}}\",\n  \"batchName\": \"Class 10 A\",\n  \"academicYear\": \"2026-27\",\n  \"userDeviceId\": \"postman-device\"\n}" },
        "url": "{{baseUrl}}/batches"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Batch created', () => {", "  pm.response.to.have.status(201);", "  pm.expect(pm.response.json().data.totalContacts).to.eql(0);", "});"] } }]
    },
    {
      "name": "3 - List Batches",
      "request": { "method": "GET", "url": "{{baseUrl}}/batches?userDeviceId=postman-device" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Batches returned', () => {", "  pm.response.to.have.status(200);", "  pm.expect(pm.response.json().data).to.be.an('array');", "});"] } }]
    },
    {
      "name": "4 - Get Batch",
      "request": { "method": "GET", "url": "{{baseUrl}}/batches/{{batchId}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Correct batch returned', () => {", "  pm.response.to.have.status(200);", "  pm.expect(pm.response.json().data.batchId).to.eql(pm.collectionVariables.get('batchId'));", "});"] } }]
    },
    {
      "name": "5 - Create Contact",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"contactUuid\": \"{{contactUuid}}\",\n  \"studentName\": \"Aarav Sharma\",\n  \"parentName\": \"Neha Sharma\",\n  \"studentNumber\": \"+919876543210\",\n  \"parentNumber\": \"+919812345678\",\n  \"rollNumber\": \"10A-01\",\n  \"batchId\": \"{{batchId}}\",\n  \"phoneContactId\": \"expo-contact-001\"\n}" },
        "url": "{{baseUrl}}/contacts"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Contact created', () => {", "  pm.response.to.have.status(201);", "  pm.expect(pm.response.json().data.batchId).to.eql(pm.collectionVariables.get('batchId'));", "});"] } }]
    },
    {
      "name": "6 - List Contacts",
      "request": { "method": "GET", "url": "{{baseUrl}}/contacts?batchId={{batchId}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Batch contacts returned', () => {", "  pm.response.to.have.status(200);", "  pm.expect(pm.response.json().pagination.total).to.eql(1);", "});"] } }]
    },
    {
      "name": "7 - Get Contact",
      "request": { "method": "GET", "url": "{{baseUrl}}/contacts/{{contactUuid}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Correct contact returned', () => {", "  pm.response.to.have.status(200);", "  pm.expect(pm.response.json().data.contactUuid).to.eql(pm.collectionVariables.get('contactUuid'));", "});"] } }]
    },
    {
      "name": "8 - Delete Contact",
      "request": { "method": "DELETE", "url": "{{baseUrl}}/contacts/{{contactUuid}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Contact deleted', () => pm.response.to.have.status(200));"] } }]
    },
    {
      "name": "9 - Delete Batch",
      "request": { "method": "DELETE", "url": "{{baseUrl}}/batches/{{batchId}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Batch deleted', () => pm.response.to.have.status(200));"] } }]
    }
  ]
}
