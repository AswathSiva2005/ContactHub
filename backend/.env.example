NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://contactsync_app:replace-with-password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=contactsync
CORS_ORIGIN=http://localhost:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
MONGODB_CONNECT_RETRIES=10
MONGODB_CONNECT_RETRY_DELAY_MS=5000
APP_LATEST_VERSION=1.0.0
APP_MINIMUM_VERSION=1.0.0
APP_APK_DOWNLOAD_URL=https://github.com/your-account/contacthub/releases/latest/download/contactsync.apk
APP_RELEASE_NOTES=Initial production release.
