{
  "expo": {
    "name": "ContactSync",
    "slug": "contactsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "contactsync",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.contactsync.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8F1FF"
      },
      "permissions": ["READ_CONTACTS", "WRITE_CONTACTS"]
    },
    "plugins": [
      "expo-router",
      ["expo-splash-screen", {"backgroundColor": "#1565C0", "imageWidth": 160}],
      ["expo-contacts", {"contactsPermission": "Allow ContactSync to save and manage imported student and parent contacts."}]
    ],
    "experiments": {"typedRoutes": true}
  }
}
